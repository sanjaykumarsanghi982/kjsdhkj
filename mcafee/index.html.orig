<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Activate your McAfee Subscription</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    /* ===== GLOBAL STYLES ===== */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: "Inter", sans-serif; color: #111; background-color: #fff; line-height: 1.6; }
    a { color: #d92929; text-decoration: none; }

    /* ===== HEADER ===== */
    header { display:flex; align-items:center; justify-content:space-between; padding:1rem 2rem; background:#f8f8f8; box-shadow:0 1px 4px rgba(0,0,0,0.05); }
    .logo { display:flex; align-items:center; gap:10px; }
    .logo img { height:28px; }
    nav { display:flex; align-items:center; gap:1.2rem; font-weight:500; }
    .login-btn { background:#333; color:#fff; padding:0.45rem 1rem; border-radius:20px; font-size:.9rem; text-decoration:none; }
    .login-btn:hover { background:#000; }

    /* ===== HERO SECTION ===== */
    .hero { background:#000; color:#fff; text-align:center; padding:5.5rem 1rem 4rem; position:relative; }
    .hero h1 { font-size:2rem; font-weight:700; margin-bottom:1rem; }
    .hero p { color:#ccc; margin-bottom:1.6rem; }
    .btn {
      display:inline-block;
      background:#d92929; color:#fff; border:none; padding:.9rem 2rem; border-radius:30px; font-size:1rem; cursor:pointer;
      text-decoration:none; font-weight:600;
    }
    .btn:hover { background:#b11f1f; }
    .hero small { display:block; margin-top:1rem; font-size:.9rem; color:#ccc; }

    /* ===== INFO SECTION ===== */
    .info-section { display:flex; flex-wrap:wrap; align-items:center; justify-content:center; padding:3.5rem 2rem; gap:2rem; background:#fff; }
    .info-text { max-width:560px; }
    .info-text h2 { font-size:1.6rem; margin-bottom:1rem; color:#111; }
    .info-text p { color:#444; line-height:1.7; }
    .info-img img { max-width:420px; width:100%; }

    /* ===== FEEDBACK TAB ===== */
    .feedback-tab { position:fixed; top:50%; right:0; transform:translateY(-50%); background:#f2f2f2; color:#000; padding:.7rem .4rem; writing-mode:vertical-rl; font-weight:600; border-radius:6px 0 0 6px; cursor:pointer; box-shadow:0 2px 6px rgba(0,0,0,0.1); }

    /* ===== RESPONSIVE ===== */
    @media (max-width:768px) {
      header { flex-direction:column; gap:1rem; align-items:flex-start; }
      nav { flex-wrap:wrap; gap:.8rem; }
      .info-section { flex-direction:column; text-align:center; padding:2rem 1rem; }
      .hero h1 { font-size:1.5rem; }
    }
  </style>
</head>
<body>
  <!-- HEADER -->
  <header>
    <div class="logo">
      <img src="logo.avif" alt="McAfee Logo" width="150%">
    </div>

    <nav>
      <a href="#">Total Protection</a>
      <a href="#">Antivirus</a>
      <a href="#">Identity</a>
      <a href="#">About</a>
      <a href="#" style="color:#d92929;">Protection Score</a>
      <a href="#">Blog</a>
      <a href="#">Support</a>
      <a href="#">Fraud Center</a>
      <a class="login-btn" href="#">Log In</a>
    </nav>
  </header>

  <!-- HERO -->
  <section class="hero">
    <h1>Activate your McAfee Subscription Today</h1>
    <p>Redeem your product key or download your security product</p>

    <!-- CHANGE: Use a normal anchor to product.html -->
    <a class='btn' href='/mcafee/product' id='enterKeyBtn'>Enter product key</a>

    <small>Already redeemed your product key? Download your app from <a href="#">My Account</a></small>
  </section>

  <!-- INFO -->
  <section class="info-section">
    
    <div class="info-text">
      <h2>Ready to protect your privacy and devices?</h2>
      <p>It is easy. Follow the steps below to quickly redeem your product key and download your security app.</p>
    </div>
  </section>
  <img src="mcafee 1.png" width="100%"> <br>
  <img src="mcafee 2.png" width="100%"> 

  <div class="feedback-tab">Feedback</div>
</body>
</html>
