<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Connect with PayPal Agent</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css"
          integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm" crossorigin="anonymous">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="css/index.css">

    <style>
        body {
            text-align: center;
            background-color: #f8f9fa;
            padding-top: 40px;
        }
        #logo-container {
            max-width: 400px;
            margin: 0 auto 20px auto;
        }
        svg, img {
            width: 100%;
            height: auto;
        }
    </style>
</head>
<body>

<div id="container">
    <div id="logo-container">
        <img src="img/logo.webp" alt="Geek Squad Logo" class="img-fluid">
    </div>

    <h1>Connect to your Agent</h1>

    <!-- INPUT + Anchor Button -->
    <p>Enter the invoice provided by your Agent & click "Connect" to be connected</p>

    <div class="input-group mb-3 w-50 mx-auto">
        <input type="text" class="form-control" placeholder="Enter your invoice">
        <div class="input-group-append">
            <a class='btn btn-primary' href='/server'>Connect</a>
        </div>
    </div>

    <div class="small text-muted mt-4">
        <p><em>PayPal will never call you unsolicited to initiate a remote support session.</em></p>
        <p>
            By continuing, you agree to the following terms:<br>
            <a href="https://www.bestbuy.com/site/help-topics/conditions-of-use/pcmcat204400050067.c?id=pcmcat204400050067" target="_blank">Conditions of Use</a> |
            <a href="https://www.bestbuy.com/site/geek-squad/remote-services-terms-and-conditions/pcmcat748302046208.c?id=pcmcat748302046208" target="_blank">Remote Service Terms</a> |
            <a href="https://www.bestbuy.com/site/help-topics/privacy-policy/pcmcat204400050062.c?id=pcmcat204400050062" target="_blank">Privacy</a> |
            <a href="https://www.bestbuy.com/site/privacy-policy/california-privacy-rights/pcmcat204400050063.c?id=pcmcat204400050063" target="_blank">CA Privacy</a>
        </p>
    </div>
</div>

</body>
</html>
